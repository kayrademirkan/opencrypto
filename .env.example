# OpenCrypto Framework — Environment Configuration
# Copy this file to .env and fill in your values.
# All settings are optional — the framework works with an empty .env.

# ─── Telegram Bot (optional — for signal notifications) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Groq AI (optional — for AI-powered trade commentary) ───
GROQ_API_KEY=
USE_LLM=true

# ─── Framework Settings (optional) ───
# OPENCRYPTO_LOG_LEVEL=INFO
# OPENCRYPTO_LOG_FORMAT=%(asctime)s [%(name)s] %(levelname)s — %(message)s
# OPENCRYPTO_DATA_DIR=./data
